# Django
SECRET_KEY=change-this-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FERNET_KEY=

# Deployment hostnames, comma-separated. Vercel deployments also auto-allow
# tcb-system.vercel.app and VERCEL_* deployment URLs.
# ALLOWED_HOSTS=tcb-system.vercel.app

# Frontend integration
FRONTEND_DEFAULT_URL=http://127.0.0.1:5505/main/index.html
FRONTEND_GENERAL_VIEWER_URL=http://127.0.0.1:5505/main/index.html
FRONTEND_APPLICANT_URL=http://127.0.0.1:5505/main/index.html
FRONTEND_EVALUATOR_URL=http://127.0.0.1:5505/main/index.html#evaluator-login
FRONTEND_ADMIN_URL=http://127.0.0.1:5505/main/index.html#admin-login
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5505
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5505

# Supabase Postgres
# Recommended: Project Settings > Database > Connection string > Transaction pooler.
# Format:
# DATABASE_URL=postgresql://postgres.<project-ref>:<database-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
DATABASE_SSLMODE=require
DATABASE_CONN_MAX_AGE=600
DATABASE_DISABLE_SERVER_SIDE_CURSORS=True

# Supabase client keys are for frontend/API clients, not Django's database connection.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
